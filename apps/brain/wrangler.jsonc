{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "shadowbox-brain",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-06",
  "compatibility_flags": ["nodejs_compat"],
  "limits": {
    "cpu_ms": 20000,
  },

  // 1. Enable Cloudflare Workers AI (Free Tier Llama-3)
  "ai": {
    "binding": "AI",
    "remote": true, // Use Cloudflare's hosted AI service
  },

  // 2. Connect to the Secure Runtime Worker
  // The 'service' name must match the 'name' in apps/secure-agent-api/wrangler.jsonc
  "services": [
    {
      "binding": "SECURE_API",
      "service": "shadowbox-api",
    },
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "RUN_ENGINE_RUNTIME",
        "class_name": "RunEngineRuntime",
      },
      {
        "name": "RUN_ENGINE_AGENT",
        "class_name": "RunEngineAgent",
      },
      {
        "name": "RUN_ADMISSION_LIMITER",
        "class_name": "RunAdmissionLimiter",
      },
    ],
  },

  "migrations": [
    {
      "tag": "v1-run-engine-runtime",
      "new_classes": ["RunEngineRuntime"],
    },
    {
      "tag": "v3-run-engine-agent",
      "new_sqlite_classes": ["RunEngineAgent"],
    },
    {
      "tag": "v4-run-admission-limiter",
      "new_sqlite_classes": ["RunAdmissionLimiter"],
    },
    {
      "tag": "v5-delete-session-memory-runtime",
      "deleted_classes": ["SessionMemoryRuntime"],
    },
  ],

  // 3. GitHub Integration Configuration
  // Add these environment variables:
  // GITHUB_CLIENT_ID, GITHUB_REDIRECT_URI, FRONTEND_URL (public)
  // GITHUB_CLIENT_SECRET, GITHUB_TOKEN_ENCRYPTION_KEY, SESSION_SECRET (secret)
  // AXIS_OPENROUTER_API_KEY (secret, required for platform-managed Axis provider)
  //
  // Production examples (LegionCode launch):
  // FRONTEND_URL=https://agents.legioncode.dev
  // GITHUB_REDIRECT_URI=https://brain.legioncode.dev/auth/github/callback
  // CORS_ALLOWED_ORIGINS=https://agents.legioncode.dev,https://legioncode.dev,https://staging.legioncode.dev
  //
  // After the landing extraction (plan 018), the agents workspace lives on
  // its own subdomain (agents.legioncode.dev). The landing app at
  // legioncode.dev is the public marketing surface only. Set FRONTEND_URL
  // to the agents subdomain so the OAuth callback redirects users back
  // into the authenticated workspace, not the marketing page.
  // HYPERDRIVE binding must be supplied by deploy-specific config with a real id.
  // DATABASE_MIGRATIONS_MODE=manual by default; set auto only for bootstrap environments.
  //
  // Launch safety knobs (optional):
  // LAUNCH_EMERGENCY_SHUTOFF_MODE=off | block_runs
  // RUN_SUBMISSION_RATE_LIMIT_MAX=60
  // RUN_SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=600
  // MUTATION_RUN_SUBMISSION_RATE_LIMIT_MAX=20
  // MUTATION_RUN_SUBMISSION_RATE_LIMIT_WINDOW_SECONDS=600
  // ACTIVE_EXPENSIVE_RUNS_PER_SESSION_MAX=1
  // ACTIVE_EXPENSIVE_RUNS_PER_USER_MAX=2
  // ACTIVE_EXPENSIVE_RUNS_PER_WORKSPACE_MAX=3
  // ACTIVE_EXPENSIVE_RUNS_ANONYMOUS_MAX=1
  // ACTIVE_EXPENSIVE_RUN_LEASE_TTL_SECONDS=900
  "vars": {
    // These should be set via wrangler secret put for production
    // GITHUB_CLIENT_SECRET
    // GITHUB_TOKEN_ENCRYPTION_KEY
    // SESSION_SECRET
    // AXIS_OPENROUTER_API_KEY
  },

  // 4. KV Namespace for Session Storage
  // Keep local dev on Miniflare KV. Remote KV makes localhost auth depend on
  // Cloudflare API reads and can intermittently fail concurrent chat requests.
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "ca477f3e873a47a7bbfd58734cc460c2",
    },
  ],

  "r2_buckets": [
    {
      "binding": "EDIT_ARTIFACTS",
      "bucket_name": "shadowbox-artifacts",
      "remote": true,
    },
  ],

  "artifacts": [
    {
      "binding": "ARTIFACTS",
      "namespace": "legioncode-edit-artifacts",
    },
  ],

  "triggers": {
    "crons": ["0 3 * * *"],
  },
}

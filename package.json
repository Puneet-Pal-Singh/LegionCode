{
  "name": "shadowbox",
  "description": "Multi-agent IDE on Cloudflare primitives",
  "private": true,
  "scripts": {
    "build": "turbo run build --continue",
    "dev": "turbo run dev",
    "lint": "turbo run lint --continue",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types --continue",
    "check:boundaries": "bash scripts/check-import-boundaries.sh",
    "gate:dev-smoke": "bash scripts/gates/run-dev-smoke.sh",
    "gate:rebuild-governance": "bash scripts/gates/run-rebuild-governance.sh",
    "gate:capability-preservation": "node scripts/gates/run-capability-preservation.mjs",
    "gate:contract-conformance": "bash scripts/gates/run-contract-conformance.sh",
    "gate:golden-repo-to-pr": "bash scripts/gates/run-golden-repo-to-pr.sh",
    "gate:staging-cutover": "bash scripts/gates/run-staging-cutover.sh",
    "gate:portability-boundary": "bash scripts/gate-portability-boundary.sh",
    "gate:runtime-conformance": "bash scripts/gate-runtime-conformance.sh",
    "e2e:phase-3.2": "bash scripts/e2e/phase-3.2-readiness.sh",
    "gate:m1.3c": "bash scripts/e2e/m1.3c-closure.sh",
    "review:sync": "bash scripts/review-script/fetch-review-comments.sh",
    "review:help": "bash scripts/review-script/fetch-review-comments.sh --help"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ai": "4.1.0",
    "framer-motion": "^12.30.0",
    "zod": "3.25.1"
  }
}
